  "pv": {
    "name": "Gigabrain Architecture",
    "version": "1.0.0",
    "description": "Local-first hybrid memory stack for intelligent agents. Captures conversation and native notes into durable, queryable memory with smart recall injection.",
    "markdown": ".principal-views/architecture.md",
    "nodeTypes": {
      "entry-point": {
        "shape": "rectangle",
        "color": "#3b82f6",
        "description": "Integration entry points (plugins, MCP servers, APIs)"
      },
      "service": {
        "shape": "rectangle",
        "color": "#22c55e",
        "description": "Core service modules"
      },
      "database": {
        "shape": "hexagon",
        "color": "#0ea5e9",
        "description": "Database and storage systems"
      },
      "store": {
        "shape": "rectangle",
        "color": "#0ea5e9",
        "description": "Data stores (event store, projection store)"
      },
      "queue": {
        "shape": "rectangle",
        "color": "#f59e0b",
        "description": "Queues and buffers"
      },
      "adapter": {
        "shape": "rectangle",
        "color": "#06b6d4",
        "description": "Protocol and interface adapters"
      },
      "rules": {
        "shape": "rectangle",
        "color": "#f43f5e",
        "description": "Policy and rule engines"
      },
      "output": {
        "shape": "rectangle",
        "color": "#14b8a6",
        "description": "Output generators (vault, metrics)"
      },
      "cli": {
        "shape": "rectangle",
        "color": "#64748b",
        "description": "CLI tools and scripts"
      },
      "config": {
        "shape": "rectangle",
        "color": "#78716c",
        "description": "Configuration and schema"
      },
      "intelligence": {
        "shape": "diamond",
        "color": "#ec4899",
        "description": "Intelligence and world model"
      }
    },
    "edgeTypes": {
      "data-flow": {
        "style": "solid",
        "color": "#64748b",
        "width": 2,
        "directed": true,
        "animation": {
          "type": "flow",
          "duration": 2000
        }
      },
      "query": {
        "style": "dashed",
        "color": "#0ea5e9",
        "width": 1,
        "directed": true
      },
      "write": {
        "style": "solid",
        "color": "#22c55e",
        "width": 2,
        "directed": true,
        "animation": {
          "type": "pulse",
          "duration": 1500
        }
      },
      "command": {
        "style": "solid",
        "color": "#8b5cf6",
        "width": 2,
        "directed": true
      },
      "validate": {
        "style": "dotted",
        "color": "#f43f5e",
        "width": 1,
        "directed": true
      },
      "enqueue": {
        "style": "dashed",
        "color": "#f59e0b",
        "width": 1,
        "directed": true
      },
      "dequeue": {
        "style": "dashed",
        "color": "#f59e0b",
        "width": 1,
        "directed": true
      },
      "persist": {
        "style": "solid",
        "color": "#0ea5e9",
        "width": 2,
        "directed": true
      },
      "orchestrate": {
        "style": "solid",
        "color": "#f97316",
        "width": 2,
        "directed": true,
        "animation": {
          "type": "flow",
          "duration": 3000
        }
      },
      "inference": {
        "style": "dashed",
        "color": "#a855f7",
        "width": 2,
        "directed": true,
        "animation": {
          "type": "particle",
          "duration": 1000
        }
      },
      "config": {
        "style": "dotted",
        "color": "#78716c",
        "width": 1,
        "directed": true
      }
    },
    "display": {
      "layout": "manual",
      "theme": {
        "primary": "#3b82f6",
        "success": "#22c55e",
        "warning": "#f59e0b",
        "danger": "#ef4444"
      },
      "animations": {
        "enabled": true,
        "speed": 1.0
      }
    }
  }
}
